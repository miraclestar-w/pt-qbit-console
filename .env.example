QBIT_URL=http://192.168.1.27:8085
# Optional fallback URL when primary is unreachable (web proxy only)
QBIT_URL_EXT=
QBIT_USERNAME=admin
QBIT_PASSWORD=admin
PORT=8787
QBIT_TIMEOUT_MS=8000
APP_INFO_TTL_MS=3600000
# Desktop widget (widget-web) reads the same QBIT_* vars
# Optional widget debug: QBIT_DEBUG=true
# Legacy aliases still work: QB_URL / QB_USER / QB_PASS / QB_DEBUG

# Daily stats collector (server)
# Sample interval (ms). Min 15000, max 900000. Default 60000.
STATS_SAMPLE_MS=60000
# Keep day files under data/daily-stats for N days (7-730). Default 90.
STATS_RETENTION_DAYS=90
# Min interval between forced samples (POST /api/stats/sample). Default 10000.
STATS_FORCE_MIN_INTERVAL_MS=10000
# Notes:
# - Cross-day snapshot carry window is maxGapMs = 15 minutes (code default).
# - Fresh maindata cache (age <= sampleMs * 2.5) is used for scheduled samples;
#   force sample always hits qB API.
# - statusWallSeconds = wall clock with >=1 torrent in status;
#   statusSeconds = task-seconds (count * interval).
