{
  "name": "pt-qbit-console",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"npm:server\" \"npm:client\"",
    "client": "vite --host 0.0.0.0",
    "server": "node server/index.mjs",
    "build": "vite build",
    "start": "node server/index.mjs --static"
  },
  "dependencies": {
    "concurrently": "^9.2.1",
    "express": "^5.1.0",
    "vite": "^6.3.5"
  }
}
